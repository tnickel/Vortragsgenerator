# =========================================================================
# Vortragsgenerator Environment Template
# Kopiere diese Datei in eine neue Datei namens '.env' und trage deine Keys ein.
# WICHTIG: Die Datei '.env' darf NIEMALS auf GitHub comittet werden!
# =========================================================================

# 1. OpenRouter API Konfiguration
# Einzubinden für die LLM-Generierung der Slides und Redetexte.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. ElevenLabs API Konfiguration
# Einzubinden für die Stimmsynthese (Voice Cloning).
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
